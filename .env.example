# ── OE Ticket — Environment Variables ──────────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to git.

# Database
POSTGRES_DB=oe_ticket_db
POSTGRES_USER=oe_ticket_user
POSTGRES_PASSWORD=change_me_in_production

# API
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=change_me_to_a_strong_32_char_secret_key
JWT_ISSUER=OETicketAPI
JWT_AUDIENCE=OETicketClient
JWT_EXPIRY_MINUTES=480

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
